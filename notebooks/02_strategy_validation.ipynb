{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Strategy Validation Notebook\n",
    "\n",
    "This notebook lets you **interactively validate** every stage of the alpha pipeline\n",
    "by calling the pure-function interfaces in `src/core/` directly.\n",
    "\n",
    "**Workflow:**\n",
    "1. Load a trained model & feature panel\n",
    "2. Generate scores (`src/core/signals`)\n",
    "3. Inspect TopK / BottomK selection (`src/core/selection`)\n",
    "4. Build a rolling portfolio (`src/core/portfolio`)\n",
    "5. Compute Spread / Alpha metrics (`src/core/metrics`)\n",
    "\n",
    "Once you are satisfied, the same functions are called by the agent in production — no black box."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, pathlib\n",
    "# Make sure src/ is on the path when running from notebooks/\n",
    "sys.path.insert(0, str(pathlib.Path.cwd().parent))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from src.core.signals import generate_scores, generate_scores_panel\n",
    "from src.core.selection import select_topk, select_bottomk\n",
    "from src.core.portfolio import build_rolling_portfolio\n",
    "from src.core.metrics import compute_spread"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Model & Feature Data\n",
    "\n",
    "Replace the placeholders below with your actual model path and feature panel."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import joblib\n",
    "\n",
    "# --- EDIT THESE PATHS ---\n",
    "MODEL_PATH   = \"../models/lgbm_latest.pkl\"   # or .txt for native LightGBM\n",
    "FEATURE_PATH = \"../data/features_test.parquet\"\n",
    "PRICE_PATH   = \"../data/close_prices.parquet\"\n",
    "BENCH_TICKER = \"SPY\"\n",
    "# -------------------------\n",
    "\n",
    "model       = joblib.load(MODEL_PATH)\n",
    "feature_panel = pd.read_parquet(FEATURE_PATH)   # MultiIndex (date, ticker)\n",
    "close         = pd.read_parquet(PRICE_PATH)     # DataFrame (date x ticker)\n",
    "print(f\"Feature panel: {feature_panel.shape}, dates: {feature_panel.index.get_level_values(0).nunique()}\")\n",
    "print(f\"Close prices : {close.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Generate Scores for a Single Date"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SAMPLE_DATE = feature_panel.index.get_level_values(0).unique()[-1]  # latest date\n",
    "print(f\"Sample date: {SAMPLE_DATE}\")\n",
    "\n",
    "feature_slice = feature_panel.xs(SAMPLE_DATE, level=0)\n",
    "scores = generate_scores(model, feature_slice)\n",
    "\n",
    "print(f\"Score distribution:\\n{scores.describe()}\")\n",
    "scores.hist(bins=50)\n",
    "plt.title(f\"Score distribution — {SAMPLE_DATE}\")\n",
    "plt.xlabel(\"score\"); plt.ylabel(\"count\"); plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Inspect TopK / BottomK Selection"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "K = 10\n",
    "\n",
    "# --- TopK with optional guardrail (price > MA60 and score > 0) ---\n",
    "# Pass prices= and ma= if you want the guardrail; omit for raw rank\n",
    "top_tickers = select_topk(scores, k=K)\n",
    "bot_tickers = select_bottomk(scores, k=K)\n",
    "\n",
    "print(f\"Long  ({len(top_tickers)}): {top_tickers}\")\n",
    "print(f\"Short ({len(bot_tickers)}): {bot_tickers}\")\n",
    "\n",
    "# Show scores side by side\n",
    "pd.concat([\n",
    "    scores[top_tickers].rename(\"long_score\"),\n",
    "    scores[bot_tickers].rename(\"short_score\"),\n",
    "], axis=1)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Build Rolling Portfolio"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate scores for the full panel\n",
    "score_panel = generate_scores_panel(model, feature_panel)\n",
    "\n",
    "# build_rolling_portfolio returns a DataFrame with columns:\n",
    "#   date, long_tickers, short_tickers, long_ret, short_ret, bench_ret, spread\n",
    "portfolio_df = build_rolling_portfolio(\n",
    "    score_panel=score_panel,\n",
    "    close=close,\n",
    "    k=K,\n",
    "    holding_days=5,\n",
    "    bench_ticker=BENCH_TICKER,\n",
    ")\n",
    "portfolio_df.tail(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Compute Spread & Alpha Metrics"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "metrics = compute_spread(\n",
    "    long_returns=portfolio_df[\"long_ret\"],\n",
    "    short_returns=portfolio_df[\"short_ret\"],\n",
    "    bench_returns=portfolio_df[\"bench_ret\"],\n",
    ")\n",
    "\n",
    "print(\"=== Strategy Metrics ===")\n",
    "for k, v in metrics.items():\n",
    "    if not isinstance(v, pd.Series):\n",
    "        print(f\"  {k:<20}: {v:.4f}\")\n",
    "\n",
    "# Plot Spread over time\n",
    "metrics[\"spread_series\"].cumsum().plot(\n",
    "    title=\"Cumulative Spread (Long - Short)\", figsize=(10, 4)\n",
    ")\n",
    "plt.axhline(0, color=\"grey\", linestyle=\"--\")\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Parameter Sweep (Optional)\n",
    "\n",
    "Quickly test different `k` values or `holding_days` to find the best configuration\n",
    "before handing off to the agent for deeper optimisation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = []\n",
    "for k_val in [5, 10, 20, 30]:\n",
    "    for hold in [3, 5, 10]:\n",
    "        pf = build_rolling_portfolio(score_panel, close, k=k_val,\n",
    "                                     holding_days=hold, bench_ticker=BENCH_TICKER)\n",
    "        m  = compute_spread(pf[\"long_ret\"], pf[\"short_ret\"], pf[\"bench_ret\"])\n",
    "        results.append({\"k\": k_val, \"holding_days\": hold,\n",
    "                         \"spread\": m[\"spread\"],\n",
    "                         \"alpha_long\": m[\"alpha_long\"],\n",
    "                         \"alpha_short\": m[\"alpha_short\"]})\n",
    "\n",
    "sweep_df = pd.DataFrame(results)\n",
    "sweep_df.sort_values(\"spread\", ascending=False)"
   ]
  }
 ],
