<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ strategy_name }} - AlphaEngine V2 Report</title>
    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .card { background-color: #1e293b; border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
    </style>
</head>
<body class="p-4 md:p-8">
    <header class="max-w-7xl mx-auto mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-blue-400">{{ strategy_name }}</h1>
            <p class="text-slate-400 mt-1 italic">AlphaEngine V2 MVP - Static Dashboard</p>
        </div>
        <div class="text-right">
            <span class="px-3 py-1 bg-blue-900/50 text-blue-300 rounded-full text-sm border border-blue-700/50">
                {{ start_date }} ➔ {{ end_date }}
            </span>
        </div>
    </header>

    <main class="max-w-7xl mx-auto space-y-6">
        <!-- Key Metrics -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="card border-l-4 border-green-500">
                <div class="text-slate-400 text-xs uppercase tracking-wider font-semibold">Total Return</div>
                <div class="text-2xl font-bold mt-1 {{ 'text-green-400' if metrics.total_return >= 0 else 'text-red-400' }}">
                    {{ "%.2f"|format(metrics.total_return * 100) }}%
                </div>
            </div>
            <div class="card border-l-4 border-slate-500">
                <div class="text-slate-400 text-xs uppercase tracking-wider font-semibold">Benchmark Return</div>
                <div class="text-2xl font-bold mt-1">
                    {{ "%.2f"|format(metrics.benchmark_return * 100) }}%
                </div>
            </div>
            <div class="card border-l-4 border-blue-500">
                <div class="text-slate-400 text-xs uppercase tracking-wider font-semibold">Alpha</div>
                <div class="text-2xl font-bold mt-1 text-blue-400">
                    {{ "%.2f"|format((metrics.total_return - metrics.benchmark_return) * 100) }}%
                </div>
            </div>
        </div>

        <!-- Equity Chart -->
        <div class="card">
            <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
                Performance Overview
            </h2>
            <div id="equity-plot" class="w-full h-[500px]"></div>
        </div>
    </main>

    <footer class="max-w-7xl mx-auto mt-12 pt-6 border-t border-slate-800 text-center text-slate-500 text-sm">
        Generated by AlphaEngine V2 Core • 100% Static HTML
    </footer>

    <script>
        const plotData = {{ plot_data_json | safe }};
        const layout = {
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor: 'rgba(0,0,0,0)',
            font: { color: '#94a3b8', family: 'Inter, system-ui, sans-serif' },
            margin: { t: 20, r: 20, b: 40, l: 60 },
            hovermode: 'x unified',
            showlegend: true,
            legend: { orientation: 'h', y: 1.1, x: 0.5, xanchor: 'center' },
            xaxis: { 
                gridcolor: '#334155', 
                linecolor: '#334155',
                type: 'date'
            },
            yaxis: { 
                gridcolor: '#334155', 
                linecolor: '#334155',
                tickprefix: '$',
                separatethousands: true
            }
        };
        
        // Customize traces
        plotData.traces.forEach(trace => {
            if (trace.name === 'Strategy') {
                trace.line = { color: '#10b981', width: 3 };
                trace.fill = 'tozeroy';
                trace.fillcolor = 'rgba(16, 185, 129, 0.1)';
            } else {
                trace.line = { color: '#94a3b8', width: 2, dash: 'dot' };
            }
        });

        Plotly.newPlot('equity-plot', plotData.traces, layout, {responsive: true});
    </script>
</body>
</html>
