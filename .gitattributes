# Auto-detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# TypeScript / JavaScript / JSON / CSS
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
.env.example text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.pkl binary
*.png binary
*.jpg binary
*.ico binary
*.db binary
