{
  "meta": {
    "name": "LGBM_v1",
    "description": "Sweep baseline: current LGBM (lr=0.05, depth=10, leaves=128)",
    "market": "cn",
    "benchmark": "000300",
    "benchmark_by_market": {
      "cn": "000300",
      "us": "QQQ"
    }
  },
  "universe": {
    "type": "watchlist",
    "filters": {
      "min_liquidity": 1000000
    },
    "custom_list": []
  },
  "model": {
    "class": "LGBModel",
    "feature_pack": "alpha158",
    "features": ["alpha158"],
    "extra_features": [
      "$close/Ref($close, 5)-1",
      "$close/Ref($close, 10)-1",
      "$close/Ref($close, 20)-1",
      "Std($close, 10)",
      "$volume/Ref($volume, 10)-1"
    ],
    "label": ["Ref($close, -10) / Ref($close, -1) - 1"],
    "train_window": {
      "train": ["2021-01-01", "2024-12-31"],
      "valid": ["2025-01-01", "2025-12-31"],
      "test": ["2026-01-01", "2026-06-25"]
    },
    "kwargs": {
      "learning_rate": 0.05,
      "lambda_l1": 1.0,
      "lambda_l2": 1.0,
      "max_depth": 10,
      "num_leaves": 128
    }
  },
  "strategy": {
    "buy_rule": "score > 0",
    "sell_rule": "score < 0",
    "rebalance_frequency": "biweekly",
    "min_hold_days": 10,
    "sell_on_ma": 60,
    "vectorized": false,
    "sell_rank_threshold": 20,
    "position_rule": {
      "topk": 5,
      "n_drop": 5
    },
    "capital": 10000,
    "costs_bps": 10,
    "backtest_window": ["2026-01-01", "2026-06-25"]
  }
}
