# =============================================================================
# Alpha Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values. All variables are optional;
# the engine starts with sensible defaults for local development.
#
# See docs/release/configuration.md for full documentation.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Runtime environment: "development" or "production"
# ALPHA_ENGINE_ENV=development

# API server bind address and port
# API_HOST=0.0.0.0
# API_PORT=8000

# Comma-separated CORS origins (overrides the built-in localhost defaults)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Dashboard HTTP Basic Auth — REQUIRED in production to protect all /api/* routes.
# When either is unset, the API returns 500 on protected endpoints.
TRADING_UI_USER=admin
TRADING_UI_PASSWORD=your-password-here

# MCP server token — when unset, MCP tools run unauthenticated (dev mode).
ALPHA_DEVELOPER_TOKEN=your-developer-token-here

# ---------------------------------------------------------------------------
# Paths (all optional — defaults are relative to project root)
# ---------------------------------------------------------------------------

# TRADING_CONFIG_DIR=configs
# TRADING_DATA_DIR=data
# TRADING_REPORTS_DIR=reports
# TRADING_SCRIPTS_DIR=scripts
# TRADING_ARTIFACTS_DIR=artifacts
# TRADING_STATIC_SITE_DIR=qlib-dashboard/dist

# Override the metadata SQLite database path (default: artifacts/metadata/metadata.db)
# TRADING_ASSISTANT_METADATA_DB_PATH=

# ---------------------------------------------------------------------------
# Risk & Limits
# ---------------------------------------------------------------------------

# Max drawdown threshold for the risk monitor (default: 0.15 = 15%)
# ALPHA_ENGINE_MAX_DRAWDOWN_THRESHOLD=0.15

# Scoring/inference timeout in seconds (default: 60)
# SCORING_TIMEOUT_SEC=60

# Max portfolio leverage multiplier (default: 1.0)
# MAX_LEVERAGE=1.0

# ---------------------------------------------------------------------------
# Integrations (optional)
# ---------------------------------------------------------------------------

# OpenAI API key — enables the research assistant LLM features
# OPENAI_API_KEY=sk-...

# Database URL for extended analytics storage
# DATABASE_URL=sqlite:///data/local_market.db

# Webhook URL for job failure alerts (Slack-compatible JSON payload)
# TRADING_WEBHOOK_URL=
