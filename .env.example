# OpenAI API Key (if needed)
OPENAI_API_KEY=your-openai-api-key-here

# Local DB / Backend configuration
DATABASE_URL=sqlite:///data/local_market.db
MARKET_DATA_PATH=data/market
MODEL_REGISTRY_PATH=artifacts/models

# Allowed limits
MAX_LEVERAGE=1.0
SCORING_TIMEOUT_SEC=60

# Authentication
ALPHA_DEVELOPER_TOKEN=your-developer-token-here
TRADING_UI_PASSWORD=your-password-here
TRADING_UI_TRUST_LOCALHOST=true
TRADING_UI_USER=admin
